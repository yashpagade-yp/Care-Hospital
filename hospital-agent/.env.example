# Telegram bot configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_MODE=polling

# Hospital backend configuration
HOSPITAL_BACKEND_BASE_URL=http://localhost:8000
HOSPITAL_API_TIMEOUT_SECONDS=30

# LLM configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Agent behavior
HOSPITAL_AGENT_ENV=development
HOSPITAL_AGENT_LOG_LEVEL=INFO

# Optional bounded memory and session state behavior
HOSPITAL_AGENT_MEMORY_ENABLED=true
HOSPITAL_AGENT_STATE_ENABLED=true
HOSPITAL_AGENT_STATE_BACKEND=sqlite
HOSPITAL_AGENT_SQLITE_PATH=./local/agent_state.db
